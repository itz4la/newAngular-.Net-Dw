                  name="OpenRowsetVariable"></property>
                <property
                  dataType="System.String"
                  description="The SQL command to be executed."
                  name="SqlCommand"
                  UITypeEditor="Microsoft.DataTransformationServices.Controls.ModalMultilineStringEditor">WITH DateCTE AS (
    SELECT CAST('2013-01-01' AS DATE) AS FullDate
    UNION ALL
    SELECT DATEADD(day, 1, FullDate)
    FROM DateCTE
    WHERE FullDate &lt; '2016-12-31'
)
SELECT 
    FullDate, 
    YEAR(FullDate) AS [Year], 
    MONTH(FullDate) AS [Month], 
    DATENAME(month, FullDate) AS MonthName, 
    DATEPART(quarter, FullDate) AS [Quarter], 
    DATENAME(weekday, FullDate) AS DayOfWeek
FROM DateCTE
OPTION (MAXRECURSION 0);</property>
                <property
